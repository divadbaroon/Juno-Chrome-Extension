{
  "manifest_version": 3,
  "name": "Juno",
  "version": "1.0",
  "permissions": 
  [
    "contextMenus",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8000/"  
  ],
  "background": 
  {
    "service_worker": "background.js" 
  },
  "action": 
  {  
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/juno_icon2.png"
    }
  },
  "icons": 
  {
    "16": "images/juno_icon2.png"
  },
  "commands": {
    "open-google": {
      "suggested_key": "Ctrl+Shift+Y",
      "description": "Opens Google"
    }
  }
}
