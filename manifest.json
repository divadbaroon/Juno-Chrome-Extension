{
  "manifest_version": 3,
  "name": "Text Processor",
  "version": "1.0",
  "permissions": 
  [
    "contextMenus",
    "activeTab",
    "scripting"  
  ],
  "host_permissions": [
    "http://localhost:8000/"  
  ],
  "background": 
  {
    "service_worker": "background.js" 
  },
  "action": 
  {  
    "default_popup": "popup.html",
    "default_icon": {
      "16": "juno_icon.png"
    }
  },
  "icons": 
  {
    "16": "juno_icon.png"
  },
  "commands": 
  {
    "_execute_action": 
    {  
      "suggested_key": 
      {
        "default": "Ctrl+Shift+Y",
        "mac": "Ctrl+Shift+Y"
      }
    }
  }
}
